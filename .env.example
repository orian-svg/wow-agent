# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Guesty webhook secret for signature verification (recommended in production)
GUESTY_WEBHOOK_SECRET=your_guesty_secret_here

# Slack incoming webhook URL for team alerts (optional — logs to console if not set)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Server port (default: 3000)
PORT=3000
